<mujoco model="go2">
  <compiler angle="radian" meshdir="assets" autolimits="true" />

  <option cone="elliptic" impratio="100" />

  <default>
    <default class="go2">
      <geom friction="0.4" margin="0.001" condim="1"/>
      <joint axis="0 1 0" damping="0.1" armature="0.01" frictionloss="0.2"/>
      <motor ctrlrange="-23.7 23.7"/>
      <!-- Joint ranges widened vs. the stock go2 for RETARGETING ONLY.
           Two reasons: (1) mink's check_limits(safety_break) raises if any joint
           starts/ends outside its range, and the stock knee range [-2.72,-0.84]
           excludes the rest value 0 -> instant crash. (2) driving the quadruped
           into an UPRIGHT, human-like walking pose needs the hind knees to
           straighten well past the stock dog range. These are visualization
           poses, not a physical go2 controller, so generous bounds are fine. -->
      <default class="abduction">
        <joint axis="1 0 0" range="-1.8 1.8"/>
      </default>
      <default class="hip">
        <default class="front_hip">
          <joint range="-3.6 3.6"/>
        </default>
        <default class="back_hip">
          <joint range="-3.6 3.6"/>
        </default>
      </default>
      <default class="knee">
        <joint range="-2.9 2.9"/>
        <motor ctrlrange="-45.43 45.43"/>
      </default>
      <default class="visual">
        <!-- group 0 so the visual meshes always render in RobotMotionViewer
             (which only toggles geom group 2 via --show_collision). -->
        <geom type="mesh" contype="0" conaffinity="0" group="0"/>
      </default>
      <default class="collision">
        <!-- Rough retargeting collision: ONE primitive per human body segment,
             named to match the kapex convention (Pelvis / Head / *_Upper_Arm /
             *_Forearm / *_Upper_Leg / *_Lower_Leg / *_Foot). Mapping follows the
             go2 IK config: front legs -> arms, rear legs -> legs.
             group 3 + red, semi-transparent for the ghost+collision preview.
             Sizes/fromto are a ROUGH first pass - tune by hand. -->
        <geom group="3" type="capsule" rgba="1 0 0 0.5"/>
      </default>
    </default>
  </default>

  <asset>
    <material name="metal" rgba=".9 .95 .95 1" />
    <material name="black" rgba="0 0 0 1" />
    <material name="white" rgba="1 1 1 1" />
